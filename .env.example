ANTHROPIC_API_KEY=
MLFLOW_TRACKING_URI=http://localhost:5000
DATABASE_URL=sqlite:///./runs.db
MODEL_TASK_TYPE=classification
DRIFT_FEATURE_THRESHOLD=0.20
EVAL_MIN_IMPROVEMENT=0.005
AGENT_MAX_TURNS=20
AIRFLOW_API_URL=http://localhost:8080
AIRFLOW_USERNAME=admin
AIRFLOW_PASSWORD=admin
RETRAIN_DAG_ID=ml_retrain_pipeline
MLFLOW_MODEL_NAME=watchtower-champion
LOG_LEVEL=INFO

# Data source configuration
DATA_SOURCE=synthetic         # synthetic | local | s3

# Local directory loader
LOCAL_REFERENCE_PATH=         # path/to/reference.csv or .parquet
LOCAL_CURRENT_PATH=           # path/to/current.csv or .parquet
LOCAL_TARGET_COLUMN=target    # column name for the label

# S3 loader
S3_BUCKET=                    # your-bucket-name
S3_REFERENCE_KEY=             # data/reference.parquet
S3_CURRENT_KEY=               # data/current.parquet
S3_TARGET_COLUMN=target
S3_REGION=us-east-1
S3_PROFILE=                   # optional AWS profile name
